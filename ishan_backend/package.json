{
  "name": "enviora-backend",
  "version": "1.0.0",
  "description": "Enviora waste management app REST API",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "db:migrate": "knex migrate:latest --knexfile src/config/knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile src/config/knexfile.js",
    "db:seed": "knex seed:run --knexfile src/config/knexfile.js"
  },
