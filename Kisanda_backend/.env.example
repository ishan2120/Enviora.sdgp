# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change these to long random strings in production!
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or leave empty for *
ALLOWED_ORIGINS=

# ── App URL (used in password-reset email links) ───────────────────────────────
APP_URL=http://localhost:3000

# ── SMTP (optional – skip to see reset tokens printed in console) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Enviora <noreply@enviora.app>
